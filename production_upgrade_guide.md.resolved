## 4. Feature 2: Streaming LLM Responses (SSE)

### Why Streaming?

| Aspect | Without Streaming | With Streaming |
|---|---|---|
| **User Experience** | User waits 3-8 seconds staring at a spinner | First token appears in ~200ms |
| **Perceived Latency** | 100% of generation time | Only time-to-first-token |
| **User Engagement** | Users might abandon | Users read as tokens arrive |
| **Production Systems** | No serious AI product does this | ChatGPT, Claude, Gemini — all stream |

### Step 1: Add Streaming to LLM Service

```python
# backend/app/services/llm_service.py — UPDATED (add streaming method)

import warnings
import asyncio
from typing import AsyncGenerator

with warnings.catch_warnings():
    warnings.simplefilter('ignore', FutureWarning)
    from google import genai

from app.config import settings

client = genai.Client(api_key=settings.GEMINI_API_KEY)

def _build_rag_prompt(query: str, context: str) -> str:
    """Builds the RAG prompt — shared between streaming and non-streaming."""
    return f"""
    You are "KnowBase AI", a premium intelligence assistant.
    Use the provided context to answer the user's question with high precision.
    
    GUIDELINES:
    1. **Structure**: Use clear paragraphs or bullet points for readability.
    2. **Emphasis**: **Bold** the most important keywords, headings, or key findings.
    3. **Citations**: Always mention the source filename using [Source: filename].
    4. **Tone**: Maintain a professional, executive command-center tone.
    
    CRITICAL: If the answer is not in the context, say:
    "I'm sorry, I couldn't find specific information about that in your uploaded documents."

    Retrieved Context:
    {context}

    User Question: {query}
    
    Helpful Answer (Structured with Markdown):
    """


# --- Existing non-streaming method (keep for backward compatibility) ---
async def generate_rag_response(query: str, context: str) -> str:
    prompt = _build_rag_prompt(query, context)
    try:
        response = client.models.generate_content(
            model='gemini-2.5-flash',
            contents=prompt
        )
        return response.text
    except Exception:
        try:
            response = client.models.generate_content(
                model='gemini-2.0-flash',
                contents=prompt
            )
            return response.text
        except Exception as e:
            raise Exception(f"Failed to generate LLM response: {str(e)}")


# --- NEW: Streaming method ---
async def generate_rag_response_stream(query: str, context: str) -> AsyncGenerator[str, None]:
    """
    Streams the LLM response token-by-token using Gemini's streaming API.
    Yields chunks of text as they arrive from the model.
    """
    prompt = _build_rag_prompt(query, context)

    try:
        # Use Gemini streaming API
        response_stream = client.models.generate_content_stream(
            model='gemini-2.5-flash',
            contents=prompt
        )

        for chunk in response_stream:
            if chunk.text:
                yield chunk.text
                # Small delay to prevent overwhelming the event loop
                await asyncio.sleep(0)

    except Exception as e:
        print(f"WARN: gemini-2.5-flash streaming failed, trying gemini-2.0-flash: {e}")
        try:
            response_stream = client.models.generate_content_stream(
                model='gemini-2.0-flash',
                contents=prompt
            )
            for chunk in response_stream:
                if chunk.text:
                    yield chunk.text
                    await asyncio.sleep(0)
        except Exception as fallback_error:
            yield f"\n\n[Error: Failed to generate response: {str(fallback_error)}]"
```

### Step 2: Add Streaming Chat Endpoint

```python
# backend/app/api/chat.py — UPDATED (add /chat/stream endpoint)

from fastapi import APIRouter, Depends, HTTPException
from fastapi.responses import StreamingResponse
from sqlalchemy.ext.asyncio import AsyncSession
from app.db.session import get_db
from app.models.user import User
from app.models.chat import Chat
from app.core.dependencies import get_current_user
from app.services.rag_service import retrieve_relevant_chunks
from app.services.llm_service import generate_rag_response, generate_rag_response_stream
from app.schemas.chat_schema import ChatRequest, ChatResponse
import json

router = APIRouter(prefix="/chat", tags=["Chat"])

# --- Existing endpoint (keep for backward compatibility) ---
@router.post("/ask", response_model=ChatResponse)
async def ask_question(
    request: ChatRequest,
    current_user: User = Depends(get_current_user),
    db: AsyncSession = Depends(get_db)
):
    context = await retrieve_relevant_chunks(db, current_user.id, request.query)
    if not context:
        raise HTTPException(status_code=404, detail="No relevant context found.")

    llm_response = await generate_rag_response(request.query, context)

    new_chat = Chat(user_id=current_user.id, query=request.query, response=llm_response)
    db.add(new_chat)
    await db.commit()
    await db.refresh(new_chat)
    return new_chat


# --- NEW: Streaming endpoint using Server-Sent Events (SSE) ---
@router.post("/stream")
async def stream_question(
    request: ChatRequest,
    current_user: User = Depends(get_current_user),
    db: AsyncSession = Depends(get_db)
):
    """
    Streams LLM response token-by-token using Server-Sent Events (SSE).
    
    SSE Format:
        data: {"token": "Hello"}
        data: {"token": " world"}
        data: {"done": true, "chat_id": "uuid"}
    """
    # 1. Retrieve context (non-streaming part, this is fast)
    context = await retrieve_relevant_chunks(db, current_user.id, request.query)
    if not context:
        raise HTTPException(status_code=404, detail="No relevant context found.")

    # 2. Stream the response
    async def event_generator():
        full_response = []

        async for token in generate_rag_response_stream(request.query, context):
            full_response.append(token)
            # SSE format: "data: {json}\n\n"
            yield f"data: {json.dumps({'token': token})}\n\n"

        # 3. After streaming completes, save to database
        complete_response = "".join(full_response)
        new_chat = Chat(
            user_id=current_user.id,
            query=request.query,
            response=complete_response
        )
        db.add(new_chat)
        await db.commit()
        await db.refresh(new_chat)

        # 4. Send completion event
        yield f"data: {json.dumps({'done': True, 'chat_id': str(new_chat.id)})}\n\n"

    return StreamingResponse(
        event_generator(),
        media_type="text/event-stream",
        headers={
            "Cache-Control": "no-cache",
            "Connection": "keep-alive",
            "X-Accel-Buffering": "no",  # Disable nginx buffering
        }
    )
```

### Step 3: Frontend — Consume SSE Stream

```typescript
// Frontend: Updated ChatBox.tsx streaming logic
// Replace the existing handleSend function's API call with this:

const handleStreamingChat = async (query: string) => {
    // Add user message immediately
    setMessages(prev => [...prev, { role: "user", content: query }]);
    
    // Add empty assistant message that will be filled token by token
    setMessages(prev => [...prev, { role: "assistant", content: "" }]);
    setLoading(true);

    try {
        const token = localStorage.getItem("token");
        const apiUrl = process.env.NEXT_PUBLIC_API_URL || "http://localhost:8000";

        const response = await fetch(`${apiUrl}/chat/stream`, {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "Authorization": `Bearer ${token}`
            },
            body: JSON.stringify({ query })
        });

        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        if (!response.body) throw new Error("ReadableStream not supported");

        const reader = response.body.getReader();
        const decoder = new TextDecoder();

        while (true) {
            const { done, value } = await reader.read();
            if (done) break;

            const text = decoder.decode(value);
            // SSE events are separated by "\n\n"
            const events = text.split("\n\n").filter(Boolean);

            for (const event of events) {
                if (!event.startsWith("data: ")) continue;
                const jsonStr = event.replace("data: ", "");
                
                try {
                    const data = JSON.parse(jsonStr);

                    if (data.token) {
                        // Append token to the last assistant message
                        setMessages(prev => {
                            const updated = [...prev];
                            const lastMsg = updated[updated.length - 1];
                            if (lastMsg.role === "assistant") {
                                lastMsg.content += data.token;
                            }
                            return updated;
                        });
                    }

                    if (data.done) {
                        console.log("Stream complete. Chat ID:", data.chat_id);
                    }
                } catch (parseErr) {
                    // Skip malformed events
                }
            }
        }
    } catch (error) {
        console.error("Streaming error:", error);
        setMessages(prev => {
            const updated = [...prev];
            const lastMsg = updated[updated.length - 1];
            if (lastMsg.role === "assistant") {
                lastMsg.content = "Sorry, an error occurred while generating the response.";
            }
            return updated;
        });
    } finally {
        setLoading(false);
    }
};
```

### SSE Data Flow Visualization

```
Timeline (seconds):
0.0s  -> POST /chat/stream { query: "What is revenue?" }
0.2s  -> [Retrieval complete, streaming starts]
0.3s  -> data: {"token": "Based"}
0.3s  -> data: {"token": " on"}
0.3s  -> data: {"token": " the"}
0.4s  -> data: {"token": " financial"}
0.4s  -> data: {"token": " documents"}
...
2.1s  -> data: {"token": " [Source: annual_report.pdf]"}
2.2s  -> data: {"done": true, "chat_id": "abc-123"}

Total time: 2.2s
Time-to-first-token: 0.3s  <-- User sees text almost instantly!
```

