## 5. Feature 3: RAG Evaluation with RAGAS

### Why Evaluate RAG?

Without evaluation, you are flying blind:
- Are you retrieving the RIGHT chunks?
- Is the LLM faithful to the context or hallucinating?
- Is the answer actually relevant to the question?

**RAGAS** (Retrieval Augmented Generation Assessment) is the industry-standard framework for evaluating RAG pipelines.

### RAGAS Metrics Explained

| Metric | What It Measures | Range | Good Score |
|---|---|---|---|
| **Context Precision** | Are the retrieved chunks actually relevant? | 0.0 to 1.0 | > 0.8 |
| **Context Recall** | Did we retrieve ALL the relevant information? | 0.0 to 1.0 | > 0.7 |
| **Faithfulness** | Is the answer grounded in the context (no hallucination)? | 0.0 to 1.0 | > 0.85 |
| **Answer Relevance** | Does the answer address the actual question? | 0.0 to 1.0 | > 0.8 |

### Step 1: Install RAGAS

```bash
pip install ragas datasets langchain-google-genai
```

Add to [requirements.txt](file:///d:/GenAI%20project/KnowBase%20AI%20%E2%80%93%20Multi-Tenant%20RAG%20SaaS%20Platform/backend/requirements.txt):
```
ragas>=0.1.0
datasets>=2.14.0
langchain-google-genai>=1.0.0
```

### Step 2: Evaluation Service

```python
# backend/app/services/eval_service.py — NEW FILE

import asyncio
from typing import Optional
from dataclasses import dataclass
from datetime import datetime

from ragas import evaluate
from ragas.metrics import (
    context_precision,
    context_recall,
    faithfulness,
    answer_relevancy,
)
from datasets import Dataset

from app.services.rag_service import retrieve_relevant_chunks
from app.services.llm_service import generate_rag_response
from sqlalchemy.ext.asyncio import AsyncSession


@dataclass
class EvalSample:
    """A single evaluation sample with ground truth."""
    question: str
    ground_truth: str  # Expected correct answer
    contexts: list[str] = None  # Will be filled by retrieval
    answer: str = None  # Will be filled by LLM


@dataclass
class EvalResult:
    """Evaluation scores for a single run."""
    context_precision: float
    context_recall: float
    faithfulness: float
    answer_relevancy: float
    num_samples: int
    timestamp: str
    details: list[dict]


# --- Sample Evaluation Dataset ---
# In production, replace with your own domain-specific Q&A pairs

SAMPLE_EVAL_DATASET = [
    EvalSample(
        question="What is the company's total revenue?",
        ground_truth="The company's total revenue for the fiscal year was $4.2 billion, representing a 15% increase year-over-year."
    ),
    EvalSample(
        question="What are the main risk factors?",
        ground_truth="The main risk factors include market volatility, regulatory changes, cybersecurity threats, and supply chain disruptions."
    ),
    EvalSample(
        question="Who is the CEO of the company?",
        ground_truth="The CEO is John Smith, who has been leading the company since 2019."
    ),
    EvalSample(
        question="What is the employee count?",
        ground_truth="The company employs approximately 12,500 people across 30 countries."
    ),
    EvalSample(
        question="What is the company's sustainability strategy?",
        ground_truth="The company aims to achieve carbon neutrality by 2030 through renewable energy adoption, waste reduction, and sustainable supply chain practices."
    ),
]


async def run_evaluation(
    db: AsyncSession,
    user_id: str,
    eval_samples: list[EvalSample] = None,
) -> EvalResult:
    """
    Runs the full RAGAS evaluation pipeline:
    1. For each question, retrieve context from user's documents
    2. Generate LLM answer
    3. Compare against ground truth using RAGAS metrics
    """
    samples = eval_samples or SAMPLE_EVAL_DATASET

    questions = []
    ground_truths = []
    contexts_list = []
    answers = []

    for sample in samples:
        # 1. Retrieve context
        context_str = await retrieve_relevant_chunks(db, user_id, sample.question)
        contexts = [context_str] if context_str else ["No context found."]

        # 2. Generate answer
        if context_str:
            answer = await generate_rag_response(sample.question, context_str)
        else:
            answer = "No relevant context found in uploaded documents."

        questions.append(sample.question)
        ground_truths.append(sample.ground_truth)
        contexts_list.append(contexts)
        answers.append(answer)

    # 3. Build RAGAS dataset
    eval_dataset = Dataset.from_dict({
        "question": questions,
        "answer": answers,
        "contexts": contexts_list,
        "ground_truth": ground_truths,
    })

    # 4. Run RAGAS evaluation
    try:
        from langchain_google_genai import ChatGoogleGenerativeAI
        from app.config import settings

        eval_llm = ChatGoogleGenerativeAI(
            model="gemini-2.0-flash",
            google_api_key=settings.GEMINI_API_KEY
        )

        result = evaluate(
            dataset=eval_dataset,
            metrics=[
                context_precision,
                context_recall,
                faithfulness,
                answer_relevancy,
            ],
            llm=eval_llm,
        )
    except Exception as e:
        print(f"RAGAS evaluation error: {e}")
        return EvalResult(
            context_precision=0.0,
            context_recall=0.0,
            faithfulness=0.0,
            answer_relevancy=0.0,
            num_samples=len(samples),
            timestamp=datetime.utcnow().isoformat(),
            details=[{"error": str(e)}]
        )

    # 5. Build result
    details = []
    for i, sample in enumerate(samples):
        details.append({
            "question": sample.question,
            "ground_truth": sample.ground_truth,
            "generated_answer": answers[i][:200] + "...",
            "context_preview": contexts_list[i][0][:200] + "...",
        })

    return EvalResult(
        context_precision=float(result["context_precision"]),
        context_recall=float(result["context_recall"]),
        faithfulness=float(result["faithfulness"]),
        answer_relevancy=float(result["answer_relevancy"]),
        num_samples=len(samples),
        timestamp=datetime.utcnow().isoformat(),
        details=details,
    )
```

### Step 3: Evaluation API Endpoint

```python
# backend/app/api/evaluation.py — NEW FILE

from fastapi import APIRouter, Depends
from sqlalchemy.ext.asyncio import AsyncSession
from app.db.session import get_db
from app.models.user import User
from app.core.dependencies import get_current_user
from app.services.eval_service import run_evaluation, EvalSample

router = APIRouter(prefix="/eval", tags=["Evaluation"])

@router.post("/run")
async def run_rag_evaluation(
    current_user: User = Depends(get_current_user),
    db: AsyncSession = Depends(get_db)
):
    """
    Runs RAGAS evaluation on the user's RAG pipeline.
    Uses a sample dataset of questions + ground truth answers.
    
    Returns scores for:
    - Context Precision (retrieved chunks relevant?)
    - Context Recall (all relevant info retrieved?)  
    - Faithfulness (answer grounded in context?)
    - Answer Relevance (answer addresses the question?)
    """
    result = await run_evaluation(db, str(current_user.id))

    return {
        "scores": {
            "context_precision": round(result.context_precision, 4),
            "context_recall": round(result.context_recall, 4),
            "faithfulness": round(result.faithfulness, 4),
            "answer_relevancy": round(result.answer_relevancy, 4),
        },
        "num_samples": result.num_samples,
        "timestamp": result.timestamp,
        "details": result.details,
        "interpretation": {
            "context_precision": "How relevant are the retrieved chunks to the question",
            "context_recall": "Did we find ALL relevant information from the documents",
            "faithfulness": "Is the answer grounded in context (no hallucination)",
            "answer_relevancy": "Does the answer actually address the question asked",
        }
    }


@router.post("/run-custom")
async def run_custom_evaluation(
    samples: list[dict],
    current_user: User = Depends(get_current_user),
    db: AsyncSession = Depends(get_db)
):
    """
    Run evaluation with custom question-answer pairs.
    
    Body: [
        {"question": "What is X?", "ground_truth": "X is..."},
        {"question": "Who is Y?", "ground_truth": "Y is..."}
    ]
    """
    eval_samples = [
        EvalSample(question=s["question"], ground_truth=s["ground_truth"])
        for s in samples
    ]

    result = await run_evaluation(db, str(current_user.id), eval_samples)

    return {
        "scores": {
            "context_precision": round(result.context_precision, 4),
            "context_recall": round(result.context_recall, 4),
            "faithfulness": round(result.faithfulness, 4),
            "answer_relevancy": round(result.answer_relevancy, 4),
        },
        "num_samples": result.num_samples,
        "details": result.details,
    }
```

